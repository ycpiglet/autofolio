{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "scripts\\update_notify_hook.cmd",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python scripts/session_dashboard.py --root .",
            "timeout": 35
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "scripts\\taskset_prompt_hook.cmd"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "scripts\\stop_hook_owner_governance.cmd",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
