#!/bin/sh
# Optional Git hook. Install with:
#   git config core.hooksPath .githooks
#
# Emergency bypass:
#   git commit --no-verify

if command -v python >/dev/null 2>&1; then
  PYTHON_BIN=python
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN=python3
else
  echo "pre-commit: python not found on PATH" >&2
  exit 1
fi

"$PYTHON_BIN" scripts/precommit_check.py || exit 1
