# Autofolio sanitized environment template.
# Copy to .env for local use. Do not commit .env.
# Keep real secrets, account numbers, OAuth clients, payment data, and provider
# tokens out of this file.

# Runtime
AUTOFOLIO_ENV=development
AUTOFOLIO_HOME=.autofolio
PORT=8000
API_INTERNAL_URL=http://127.0.0.1:8000
AUTOFOLIO_PUBLIC_BASE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3000
AUTOFOLIO_FRONTEND_HOME_URL=http://127.0.0.1:3000/home
AUTOFOLIO_FRONTEND_LOGIN_URL=http://127.0.0.1:3000/login

# Safety defaults
KIS_ENV=mock
AUTOFOLIO_LOCAL_AUTO_REGISTER=0
AUTOFOLIO_GUEST_DEMO_ENABLED=0
AUTOFOLIO_SSO_MOCK_ENABLED=0
AUTOFOLIO_KIS_WS_ENABLE=0

# SSO owner designation — REQUIRED for SSO owner login. When unset, every SSO
# login is denied (403) by design (closes the "any allowlisted email = owner" hole).
# If AUTOFOLIO_SSO_ALLOWED_EMAILS is non-empty, this email must ALSO be in it.
AUTOFOLIO_OWNER_EMAIL=
# Production capability locks (all default OFF / fail-closed). Enabling auto-exec
# or recommendation/advice output requires explicit opt-in here.
AUTOFOLIO_AUTO_EXEC_ENABLED=0
AUTOFOLIO_RECOMMENDATION_ENABLED=0
AUTOFOLIO_ADVICE_ENABLED=0
AUTOFOLIO_MULTI_TENANT_ENABLED=0

# Membership signup and manual deposit placeholders
AUTOFOLIO_MEMBERSHIP_PRICE_KRW=0
AUTOFOLIO_MEMBERSHIP_BANK_NAME=
AUTOFOLIO_MEMBERSHIP_ACCOUNT_HOLDER=
AUTOFOLIO_MEMBERSHIP_BANK_ACCOUNT=

# SSO allowlist and mock-only local testing
AUTOFOLIO_SSO_ALLOWED_EMAILS=
AUTOFOLIO_SSO_MOCK_CODE=
AUTOFOLIO_SSO_MOCK_EMAIL=
AUTOFOLIO_SSO_MOCK_NAME=
AUTOFOLIO_SSO_MOCK_SUBJECT=

# Google SSO
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTOFOLIO_GOOGLE_CLIENT_ID=
AUTOFOLIO_GOOGLE_CLIENT_SECRET=

# Kakao SSO
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
AUTOFOLIO_KAKAO_REST_API_KEY=
AUTOFOLIO_KAKAO_CLIENT_SECRET=

# Naver SSO
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
AUTOFOLIO_NAVER_CLIENT_ID=
AUTOFOLIO_NAVER_CLIENT_SECRET=

# Supabase staging placeholders
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database backend selector. Leave EMPTY for the default local SQLite path
# (byte-identical to historical behaviour). Set to a postgres://|postgresql://
# connection string to route the DB seam onto Postgres (e.g. autofolio-staging
# Supabase). Do NOT commit a real URL/password here — supply it at deploy time.
DATABASE_URL=

# KIS placeholders. Keep KIS_ENV=mock unless Owner explicitly authorizes paper/prod.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=
KIS_PAPER_ACCOUNT_PRODUCT_CODE=
KIS_PAPER_HTS_ID=
KIS_PROD_APP_KEY=
KIS_PROD_APP_SECRET=
KIS_PROD_ACCOUNT_NO=
KIS_PROD_ACCOUNT_PRODUCT_CODE=
KIS_PROD_HTS_ID=

# Optional LLM and notification integrations
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
