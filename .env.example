# ------------------------------------------------------------
# Environment
# ------------------------------------------------------------
# mock | paper | prod
KIS_ENV=mock

# ------------------------------------------------------------
# KIS Open API credentials
# ------------------------------------------------------------
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=

# Optional endpoint overrides.
# Fill these from the official KIS Open API portal/docs when implementing.
KIS_BASE_URL=
KIS_TOKEN_PATH=

# ------------------------------------------------------------
# Telegram
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# AI 에이전트 (Anthropic) — 에이전트 실연결 / 투자위원회(IC)
# 키가 없으면 데모 스텁으로 동작한다.
# ------------------------------------------------------------
ANTHROPIC_API_KEY=
# 선택: 모델/에포트 (기본 claude-opus-4-8 / medium). 비용 절감 시 claude-sonnet-4-6 등.
AUTOFOLIO_LLM_MODEL=
AUTOFOLIO_LLM_EFFORT=

# ------------------------------------------------------------
# Local settings
# ------------------------------------------------------------
DB_PATH=trading_bot.db
