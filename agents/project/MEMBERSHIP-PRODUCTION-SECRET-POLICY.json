    "secret_metadata_rls_staging_tests_pass",
    "supabase_security_advisor_reviewed",
    "policy_gate_passes",
    "production_secret_store_selected",
    "encryption_key_management_reviewed",
    "write_redaction_delete_tests_pass",
    "rotation_path_tested",
    "audit_event_schema_reviewed",
    "provider_oauth_flows_reviewed",
    "kis_credential_scope_reviewed",
    "incident_response_runbook_written"
  ],
  "verification": {
    "local_policy_gate": "python scripts/membership_secret_policy_gate.py --check",
    "readiness_api_test": ".venv\\Scripts\\python.exe -m pytest tests/api/test_membership.py -q",
    "integration_api_reference_test": ".venv\\Scripts\\python.exe -m pytest tests/api/test_integrations.py -q",
    "forbidden_actions": [
      "secret read",
      "secret write",
      "secret rotation",
      "provider API call",
      "OAuth callback validation",
      "KIS credential activation",
      "production DB write",
      "external deploy"
    ]
  }
