  "source_basis": [
    "Supabase changelog checked 2026-06-19: secret keys now have GitHub Push Protection and anon access to the OpenAPI spec is deprecated, reinforcing server-side secret handling.",
    "Supabase API key docs checked 2026-06-19: publishable keys are browser-safe only with RLS; secret keys bypass RLS and must be backend-only.",
    "Supabase Edge Function secrets docs checked 2026-06-19: secret/service keys are safe in Edge Functions but must never be used in a browser.",
    "Supabase Vault docs checked 2026-06-19: Vault stores secrets encrypted on disk and exposes decrypted values through a database view, so decrypted access must be server-only and reviewed.",
    "Owner direction: verified signup, account-only service, and user-owned LLM/SNS/KIS tokens without Autofolio operating user assets."
  ],
  "purpose": "Define the production secret/token boundary for user-owned LLM, SNS, OAuth, and KIS credentials before external-user launch.",
  "non_goals": [
    "No secret value is stored, read, rotated, validated, or migrated by this policy.",
    "No provider API, OAuth callback, KIS API, Supabase project, production DB, or deploy action is performed by this policy.",
    "No Owner, member, or customer credential is committed to repository files.",
    "No production key-management vendor or legal/compliance conclusion is finalized by this policy."
  ],
  "boundaries": {
    "not_applied_to_production": true,
    "no_secret_values": true,
    "no_secret_read": true,
    "no_secret_write": true,
    "no_provider_api_call": true,
    "no_oauth_callback_validation": true,
    "no_kis_credential_activation": true,
    "no_external_network_action_required": true,
    "keeps_can_launch_false": true
  },
  "secret_classes": [
