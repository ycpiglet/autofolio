      "id": "supabase_publishable_key",
      "scope": "platform",
      "browser_allowed": true,
      "conditions": [
        "RLS enabled on exposed tenant tables",
        "least-privilege grants reviewed",
        "no private data exposed without auth.uid() ownership"
      ],
      "plaintext_response_allowed": true,
      "rotation_required": true
    },
    {
      "id": "supabase_secret_key",
      "scope": "platform",
      "browser_allowed": false,
      "server_only": true,
      "bypasses_rls": true,
      "plaintext_response_allowed": false,
      "rotation_required": true
    },
    {
      "id": "legacy_service_role_key",
      "scope": "platform",
      "browser_allowed": false,
      "server_only": true,
      "bypasses_rls": true,
      "plaintext_response_allowed": false,
      "rotation_required": true,
      "replacement_preferred": "supabase_secret_key"
    },
    {
      "id": "user_llm_api_token",
      "scope": "tenant_user_owned",
      "user_scoped": true,
      "browser_allowed": false,
      "server_only_decryption": true,
      "plaintext_response_allowed": false,
      "rotation_required": true
    },
    {
      "id": "user_sns_oauth_token",
      "scope": "tenant_user_owned",
      "user_scoped": true,
      "browser_allowed": false,
      "server_only_decryption": true,
      "plaintext_response_allowed": false,
      "rotation_required": true
    },
    {
      "id": "user_kis_credential",
      "scope": "tenant_user_owned",
      "user_scoped": true,
      "browser_allowed": false,
      "server_only_decryption": true,
      "plaintext_response_allowed": false,
      "rotation_required": true,
      "requires_kis_terms_review": true
    },
    {
      "id": "membership_bank_runtime_config",
      "scope": "owner_runtime_config",
      "browser_allowed": false,
      "server_only": true,
      "plaintext_response_allowed": false,
      "rotation_required": true
    }
  ],
  "storage_targets": [
    {
      "id": "server_runtime_environment",
      "use_for": [
        "deployment platform secret variables",
        "Supabase Edge Function secrets",
        "Railway or equivalent backend runtime secrets"
      ],
      "encrypted_at_rest_required": true,
      "plaintext_browser_access": false,
      "repository_storage_allowed": false
    },
    {
      "id": "supabase_vault_or_equivalent_kms",
      "use_for": [
        "tenant user-owned provider token payloads",
        "server-side automation credentials after Owner approval"
      ],
      "encrypted_at_rest_required": true,
      "decrypted_access_server_only": true,
      "direct_client_query_forbidden": true,
      "requires_access_review": true
    },
    {
      "id": "tenant_secret_metadata_table",
      "use_for": [
        "provider id",
        "enabled state",
        "masked hint",
        "secret reference id",
        "last rotated timestamp",
        "last used timestamp"
      ],
      "contains_plaintext_secret": false,
      "user_id_required": true,
      "rls_required": true,
      "member_policy": "select own metadata where (select auth.uid()) = user_id"
    }
  ],
