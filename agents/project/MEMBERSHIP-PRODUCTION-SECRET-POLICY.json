  "retained_metadata_fields": [
    "user_id",
    "provider_id",
    "provider_kind",
    "auth_type",
    "account_label",
    "scopes",
    "enabled",
    "secret_set",
    "secret_hint",
    "created_at",
    "updated_at",
    "last_checked_at",
    "status",
    "rotation_due_at",
    "deletion_requested_at",
    "audit_event_id"
  ],
  "forbidden_exposure": [
    "browser_bundle",
    "NEXT_PUBLIC_or_client_prefixed_env",
    "repository_file",
    "logs_or_trace_payload",
    "url_or_query_parameter",
    "api_response_plaintext",
    "client_side_decryption",
    "user_metadata_or_client_editable_jwt_claim",
    "routine_admin_plaintext_read",
    "plaintext_secret_response",
    "secret_value_in_url",
    "secret_value_in_log",
    "secret_value_in_task_record",
    "secret_value_in_report",
    "secret_value_in_browser_storage",
    "service_key_in_browser_bundle",
    "raw_oauth_token_event",
    "committed_env_file",
    "provider_validation_without_owner_approval",
    "kis_credential_activation_without_owner_approval"
  ],
  "redaction_rules": [
    {
      "id": "response_secret_set_boolean",
      "action": "return secret_set true or false instead of value"
    },
    {
      "id": "masked_hint_max_6",
      "action": "show at most six non-sensitive leading characters for correlation",
      "max_visible_chars": 6
    },
    {
      "id": "hash_secret_identifier",
      "action": "store SHA256 or equivalent hash for valid key correlation instead of the raw secret"
    },
    {
      "id": "log_sanitization",
      "action": "strip Authorization, apikey, token, password, secret, and provider credential fields before logging"
    },
    {
      "id": "mask_secret_to_suffix",
      "pattern_class": "any_secret_or_token",
      "action": "return_suffix_hint_only",
      "max_visible_chars": 4
    },
    {
      "id": "bound_account_label",
      "pattern_class": "user_supplied_label",
      "action": "normalize_and_bound_length",
      "max_chars": 160
    },
    {
      "id": "allowed_scope_names_only",
      "pattern_class": "provider_scope_list",
      "action": "dedupe_normalized_scope_names",
      "max_items": 12
    },
    {
      "id": "no_plaintext_last_checked_error",
      "pattern_class": "provider_error_or_validation_status",
      "action": "store_status_without_raw_secret",
      "max_chars": 240
    }
  ],
  "lifecycle_actions": [
    {
      "id": "write_or_replace_secret",
      "actor": "authenticated_member",
      "plaintext_returned": false,
      "provider_called": false,
      "requires_csrf": true,
      "audit_required": true
    },
    {
      "id": "disable_without_delete",
      "actor": "authenticated_member",
      "plaintext_returned": false,
      "provider_called": false,
      "requires_csrf": true,
      "audit_required": true
    },
    {
      "id": "delete_secret",
      "actor": "authenticated_member",
      "plaintext_returned": false,
      "provider_called": false,
      "requires_csrf": true,
      "audit_required": true
    },
    {
      "id": "rotate_secret",
      "actor": "authenticated_member",
      "plaintext_returned": false,
      "provider_called": false,
      "requires_csrf": true,
      "audit_required": true
    },
    {
      "id": "owner_support_redacted_metadata_read",
      "actor": "owner_admin",
      "plaintext_returned": false,
      "provider_called": false,
      "requires_csrf": true,
      "audit_required": true
    }
  ],
  "lifecycle_operations": [
    {
      "id": "create_write_only",
      "allowed_actor": "authenticated owner/member for own tenant or Owner admin for audited support",
      "plaintext_returned": false,
      "audit_event_required": true,
      "metadata_response_only": true
    },
    {
      "id": "rotate_without_plaintext_read",
      "allowed_actor": "authenticated owner/member for own tenant or Owner admin for audited support",
      "plaintext_returned": false,
      "audit_event_required": true,
      "previous_secret_invalidated": true
    },
    {
      "id": "delete_or_revoke",
      "allowed_actor": "authenticated owner/member for own tenant or Owner admin for audited support",
      "plaintext_returned": false,
      "audit_event_required": true,
      "metadata_tombstone_allowed": true
    },
    {
      "id": "disable_without_delete",
      "allowed_actor": "authenticated owner/member for own tenant or Owner admin for audited support",
      "plaintext_returned": false,
      "audit_event_required": true,
      "provider_execution_blocked": true
    },
    {
      "id": "incident_response",
      "allowed_actor": "Owner with platform console access",
      "plaintext_returned": false,
      "audit_event_required": true,
      "requires_root_cause_record": true
    }
  ],
  "audit_invariants": [
    {
      "id": "service_secret_key_server_only",
      "statement": "Supabase secret/service keys are only present in server-side runtime secret stores and never in browser code, logs, reports, or repository files."
    },
    {
      "id": "publishable_key_requires_rls",
      "statement": "Publishable or legacy anon keys may be public only when RLS and least-privilege grants protect exposed tenant tables."
    },
    {
      "id": "tenant_secrets_write_only",
      "statement": "User-owned LLM/SNS/KIS tokens are accepted only through write requests and are never returned after storage."
    },
    {
      "id": "decrypted_secret_view_server_only",
      "statement": "If Supabase Vault or an equivalent KMS is used, decrypted secret access is restricted to server-side code paths with reviewed access."
    },
    {
      "id": "secret_metadata_user_scoped",
      "statement": "Secret metadata includes user_id, provider, enabled state, masked hint, and secret reference, with member access scoped by auth.uid()."
    },
    {
      "id": "rotation_and_delete_audited",
      "statement": "Secret create, rotate, disable, delete, and incident response operations create audit events without storing plaintext."
    },
    {
      "id": "no_client_side_decryption",
      "statement": "Client code never receives keys, encrypted payloads plus decryption material, or decrypted provider credentials."
    },
    {
      "id": "no_secret_in_user_metadata",
      "statement": "Secrets and authorization decisions are not stored in client-editable user metadata."
    },
    {
      "id": "server_side_only_storage",
      "statement": "Production secret material is stored only in a server-side secret store or encrypted server database column, never in browser storage."
    },
    {
      "id": "write_only_api_boundary",
      "statement": "APIs may accept secret material in request bodies, but never return it after storage."
    },
    {
      "id": "response_metadata_only",
      "statement": "Responses expose only provider metadata, configured state, enabled state, masked hint, timestamps, and status."
    },
    {
      "id": "delete_removes_secret_material",
      "statement": "Deletion removes secret material and leaves only an audited metadata event."
    },
    {
      "id": "rotation_replaces_and_audits",
      "statement": "Rotation replaces the previous secret material, records an audit event, and does not expose either value."
    },
    {
      "id": "no_provider_call_during_policy_gate",
      "statement": "This local policy gate does not call OpenAI, Anthropic, Telegram, Google, Naver, Kakao, X, KIS, OAuth, Supabase, or deployment targets."
    },
    {
      "id": "no_secret_in_repo_or_logs",
      "statement": "Secret material must not appear in repository files, task records, reports, logs, screenshots, or generated artifacts."
    },
    {
      "id": "user_scope_from_auth_session",
      "statement": "Self-service secret operations derive user scope from the authenticated session, not from request body user identifiers."
    },
    {
      "id": "owner_admin_plaintext_read_forbidden",
      "statement": "Owner/admin support surfaces may read redacted metadata, but routine plaintext secret readback is forbidden."
    }
  ],
  "launch_gates": [
    "backend_only_secret_access_reviewed",
    "incident_rotation_runbook_recorded",
    "kis_terms_secret_use_reviewed",
    "platform_access_roles_reviewed",
