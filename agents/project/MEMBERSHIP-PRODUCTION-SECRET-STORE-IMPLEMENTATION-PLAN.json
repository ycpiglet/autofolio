  "rotation_delete_audit_checklist": [
    {
      "id": "create_metadata_only_response",
      "assertion": "Write or replace accepts secret material in the request body but returns only metadata, masked hint, and audit event id.",
      "plaintext_secret_read_required": false,
      "provider_call_required": false,
      "audit_required": true
    },
    {
      "id": "rotate_replaces_reference_without_readback",
      "assertion": "Rotation creates a new secret reference, disables or tombstones the old reference, and never reads the old plaintext into the response.",
      "plaintext_secret_read_required": false,
      "provider_call_required": false,
      "audit_required": true
    },
    {
      "id": "disable_blocks_execution_without_delete",
      "assertion": "Disable flips metadata so worker execution refuses the provider without deleting secret material.",
      "plaintext_secret_read_required": false,
      "provider_call_required": false,
      "audit_required": true
    },
    {
      "id": "delete_removes_payload_and_leaves_tombstone",
      "assertion": "Delete removes secret payload material and keeps only an audited tombstone or non-sensitive metadata.",
      "plaintext_secret_read_required": false,
      "provider_call_required": false,
      "audit_required": true
    },
    {
      "id": "owner_support_redacted_metadata_only",
      "assertion": "Owner support can inspect provider id, enabled state, masked hint, and status only.",
      "plaintext_secret_read_required": false,
      "provider_call_required": false,
      "audit_required": true
    },
    {
      "id": "incident_response_rotation_path",
      "assertion": "Incident response can disable and rotate affected references with audit evidence and no plaintext report/log output.",
      "plaintext_secret_read_required": false,
      "provider_call_required": false,
      "audit_required": true
    }
  ],
  "required_staging_tests": [
    "member_a_cannot_read_member_b_secret_metadata",
    "member_a_cannot_update_member_b_secret_metadata",
    "secret_write_returns_metadata_only",
    "secret_rotate_returns_metadata_only",
