  "purpose": "Turn TASK-112 production secret policy into a concrete implementation plan for staging review without reading, writing, validating, rotating, or storing any real secret.",
  "non_goals": [
    "No secret value is stored, read, returned, rotated, deleted, validated, migrated, or generated by this plan.",
    "No OAuth callback, provider token validation, KIS credential activation, Supabase project mutation, production database write, deploy, or environment write is performed by this plan.",
    "No production secret store vendor or legal/compliance conclusion is final until Owner/R3 approval."
  ],
  "boundaries": {
    "not_applied_to_production": true,
    "no_secret_values": true,
    "no_secret_read": true,
    "no_secret_write": true,
    "no_provider_api_call": true,
    "no_oauth_callback_validation": true,
    "no_kis_credential_activation": true,
    "no_supabase_project_mutation": true,
    "no_production_db_apply": true,
    "no_external_network_action_required": true,
    "keeps_can_launch_false": true
  },
  "recommended_architecture": {
    "summary": "Use runtime/Edge Function secrets for platform-owned backend keys and a tenant secret payload store such as Supabase Vault or equivalent KMS for user-owned provider tokens. Store only metadata and secret references in tenant tables.",
    "platform_secret_lane": "deployment_runtime_secrets or supabase_edge_function_secrets",
    "tenant_secret_lane": "supabase_vault_or_equivalent_kms",
    "tenant_metadata_lane": "tenant_secret_metadata_table",
    "selection_status": "recommended_for_review_not_selected_or_applied",
    "reasoning": [
      "Platform secret keys bypass RLS and belong only in server-side runtime secrets.",
      "Tenant user-owned provider tokens need per-user metadata, rotation/delete audit, and server-only decrypted access.",
      "Supabase Vault is a reasonable staging candidate because it stores encrypted secrets in Postgres, but its decrypted view requires strict server-side access review.",
      "An external KMS remains a future option if compliance, audit, or operational separation requires it."
    ]
  },
  "candidate_stores": [
    {
      "id": "deployment_runtime_secrets",
      "production_status": "not_implemented",
      "use_for": [
        "backend platform configuration",
        "deployment provider secret variables",
        "non-tenant platform integration values after Owner approval"
      ],
      "plaintext_browser_access": false,
      "repository_storage_allowed": false,
      "server_only_decryption": true,
      "rotation_supported_by_plan": true,
      "access_review_required": true,
      "limitations": [
        "Not suitable as the only store for many dynamic user-owned tokens.",
        "Requires deployment-provider access control and incident runbook."
      ]
    },
    {
      "id": "supabase_edge_function_secrets",
      "production_status": "not_implemented",
      "use_for": [
        "Supabase Edge Function platform secrets",
        "server-side function access to publishable/secret key dictionaries"
      ],
      "plaintext_browser_access": false,
      "repository_storage_allowed": false,
      "server_only_decryption": true,
      "rotation_supported_by_plan": true,
      "access_review_required": true,
      "limitations": [
        "Secret keys bypass RLS and must stay backend-only.",
        "Do not use this as client-visible configuration."
      ]
    },
    {
      "id": "supabase_vault_or_equivalent_kms",
      "production_status": "not_implemented",
      "use_for": [
        "tenant user-owned LLM API keys",
        "tenant user-owned SNS/OAuth token payloads",
        "future user-owned KIS credential payloads after terms review"
      ],
      "plaintext_browser_access": false,
      "repository_storage_allowed": false,
      "server_only_decryption": true,
      "rotation_supported_by_plan": true,
      "access_review_required": true,
      "limitations": [
        "Supabase Vault exposes decrypted secrets through a database view; direct client or broad role access is forbidden.",
        "Staging must prove decrypted access is restricted to reviewed server-side paths."
      ]
    },
    {
      "id": "tenant_secret_metadata_table",
      "production_status": "not_implemented",
      "use_for": [
        "provider id",
        "auth type",
        "enabled state",
        "secret reference id",
        "masked hint",
        "rotation/delete timestamps",
        "audit event id"
      ],
      "contains_plaintext_secret": false,
      "plaintext_browser_access": false,
      "repository_storage_allowed": false,
      "user_id_required": true,
      "rls_required": true,
      "access_review_required": true,
      "limitations": [
        "Must never store raw provider token payloads.",
        "Must not allow user_id reassignment on update."
      ]
    },
    {
      "id": "external_kms_future_option",
      "production_status": "not_selected",
      "use_for": [
        "future compliance-driven separation from Supabase database",
        "future envelope encryption or dedicated KMS path"
      ],
      "plaintext_browser_access": false,
      "repository_storage_allowed": false,
      "server_only_decryption": true,
      "rotation_supported_by_plan": true,
      "access_review_required": true,
      "limitations": [
        "Requires vendor selection, cost review, audit model, and Owner approval.",
        "No account setup or credential creation is part of TASK-118."
      ]
    }
  ],
