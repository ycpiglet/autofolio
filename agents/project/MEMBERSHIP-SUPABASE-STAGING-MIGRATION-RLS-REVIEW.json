  "rls_review_requirements": [
    "Every table in table_review_specs must have RLS enabled before external users.",
    "Every authenticated member policy must combine TO authenticated with auth.uid ownership intent.",
    "Every update-capable tenant table must have a WITH CHECK ownership rule.",
    "Append-only tables must not grant authenticated update or delete.",
    "Anon must have no direct tenant table access; public signup/status lookup stays backend-mediated.",
    "Owner/admin cross-tenant operations must be server-side and append audit events.",
    "Service role or secret keys are server-runtime only and never browser-visible."
  ],
