  "required_staging_tests": [
    {"id": "anon_has_no_tenant_table_access", "assertion": "anon cannot select, insert, update, or delete tenant-owned rows through Data API"},
    {"id": "member_a_cannot_read_member_b", "assertion": "member A cannot select member B rows for every tenant-owned table"},
    {"id": "member_a_cannot_update_member_b", "assertion": "member A cannot update member B rows and update returns no affected rows or fails"},
    {"id": "member_cannot_reassign_user_id", "assertion": "UPDATE with user_id changed to another user is blocked by WITH CHECK"},
    {"id": "member_cannot_call_owner_admin", "assertion": "member cannot execute membership approval, grant, engine override, or support admin paths"},
    {"id": "owner_admin_routes_create_audit_events", "assertion": "owner/admin cross-tenant actions append audit_events with actor_user_id and target_user_id"},
    {"id": "secret_metadata_never_returns_plaintext", "assertion": "secret create/update/delete returns only metadata, configured state, and masked hint"},
    {"id": "payment_evidence_minimized", "assertion": "payment evidence rows contain retained allowlist fields only and no raw pasted statement"},
    {"id": "engine_queue_user_scope", "assertion": "worker queue claim cannot select or mutate another user's queue item"},
    {"id": "order_intent_append_only", "assertion": "members cannot update/delete order_intents, order_logs, or execution_logs"}
  ],
