    "checked_at": "2026-06-19T20:20:16+09:00",
    "retrieval_method": "read-only curl fetch of official Supabase documentation",
    "official_sources": [
      "https://supabase.com/changelog.md",
      "https://supabase.com/docs/guides/database/postgres/row-level-security.md",
      "https://supabase.com/docs/guides/api/securing-your-api.md",
      "https://supabase.com/docs/guides/security/product-security.md"
    ],
    "changelog_items": [
      "2026-04-28 Data/API exposure breaking change: new public schema tables are not automatically exposed to the Data/GraphQL API for new projects.",
      "RLS guidance: use policy TO clauses such as TO authenticated plus auth.uid() ownership predicates.",
      "RLS update guidance: UPDATE policies need both USING and WITH CHECK.",
      "Security guidance: do not use user-editable user_metadata for authorization, and never expose service key, service_role, or secret keys to clients."
    ]
  },
  "non_goals": [
    "No SQL migration file is created.",
    "No app/database/schema.sql change is made.",
    "No Supabase project is connected or mutated.",
    "No production DB, staging DB, Edge Function, storage bucket, or Data API setting is changed.",
    "No real customer PII, payment record, bank account number, provider token, KIS key, OAuth secret, or runtime secret is stored."
  ],
  "global_invariants": [
    "Every tenant-owned table has RLS enabled before any Data API grant or exposure is used for external users.",
    "Member policies combine TO authenticated with (select auth.uid()) ownership checks.",
    "Role-only policies are forbidden for tenant-private, financial, control, trading, product, secret metadata, and audit tables.",
    "UPDATE policies include both USING and WITH CHECK so a user cannot reassign user_id or target_user_id.",
    "Authorization data must come from auth.uid(), server session context, or app_metadata, never client-editable user_metadata.",
    "Owner/admin cross-tenant operations are server-audited and never rely on browser service keys.",
    "Data API exposure is explicit: table grants and exposed-table settings must be reviewed separately from RLS.",
    "SECURITY DEFINER is avoided by default; if required later, it must live outside public API schemas, set an explicit search_path, check auth.uid(), and be advisor-reviewed.",
    "can_launch remains false until staging schema/RLS/apply, cross-user tests, security advisors, and deploy smoke evidence exist."
  ],
  "data_api_access_model": {
    "default_for_tenant_tables": "not_exposed_until_rls_and_grants_reviewed",
    "anon": "no tenant table grants; public pre-auth routes use backend APIs only",
    "authenticated": "least privilege per table after RLS policies exist",
    "service_role_or_secret_key": "server runtime only; no browser exposure",
    "grant_order": [
      "create/review table design",
      "enable RLS",
      "create ownership policies",
      "add staging cross-user tests",
      "review Data API exposure settings",
      "grant least privilege to anon/authenticated only when needed",
      "run security and performance advisors"
    ]
  },
