# Autofolio 시크릿 예시. 실제 값은 .streamlit/secrets.toml 로 복사해서 채운다(gitignore됨).
#
# --- Google 소셜 로그인(OIDC, st.login) ---
# Google Cloud Console에서 OAuth 클라이언트(웹) 1회 생성 후 아래를 채우면
# 로그인 화면의 "Google로 시작" 버튼이 1클릭으로 동작한다.
#
# [auth]
# redirect_uri = "http://localhost:8501/oauth2callback"
# cookie_secret = "아무_긴_랜덤_문자열"
# client_id = "xxxxx.apps.googleusercontent.com"
# client_secret = "xxxxx"
# server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
#
# Kakao/Naver는 streamlit-oauth 컴포넌트로 확장(P1.0c+).
